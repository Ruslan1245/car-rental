<div class="cr-reviews" style="background: {{ section.settings.background_color }}; padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;">
  {% if section.settings.heading != blank %}
    <div class="cr-reviews__heading-wrap">
      <h2 class="cr-reviews__heading">{{ section.settings.heading }}</h2>
    </div>
  {% endif %}
  <div class="cr-reviews__nav">
    <button class="cr-reviews__arrow cr-reviews__arrow--prev" aria-label="Previous">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6"/>
      </svg>
    </button>
    <button class="cr-reviews__arrow cr-reviews__arrow--next" aria-label="Next">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 18 15 12 9 6"/>
      </svg>
    </button>
  </div>
  <div class="cr-reviews__track-wrap">
    <div class="cr-reviews__track" id="cr-reviews-track-{{ section.id }}">
      {% for block in section.blocks %}
        {% if block.type == 'review' %}
          <div class="cr-reviews__card" {{ block.shopify_attributes }}>
            <div class="cr-reviews__stars">
              {% for i in (1..5) %}
                {% if i <= block.settings.rating %}
                  <span class="cr-reviews__star cr-reviews__star--filled">★</span>
                {% else %}
                  <span class="cr-reviews__star">★</span>
                {% endif %}
              {% endfor %}
            </div>
            <div class="cr-reviews__text-wrap">
              <p class="cr-reviews__text">
                <span class="cr-reviews__quote">&ldquo;</span>{{ block.settings.review_text }}<span class="cr-reviews__quote">&rdquo;</span>
              </p>
              <button class="cr-reviews__readmore" aria-expanded="false">read more</button>
            </div>
            <div class="cr-reviews__author">
              <div class="cr-reviews__avatar">
                {% if block.settings.avatar != blank %}
                  {{ block.settings.avatar | image_url: width: 48 | image_tag: width: 48, height: 48, loading: 'lazy' }}
                {% else %}
                  <span>{{ block.settings.author_name | slice: 0 | upcase }}</span>
                {% endif %}
              </div>
              <div class="cr-reviews__author-info">
                <span class="cr-reviews__author-name">{{ block.settings.author_name }}</span>
                {% if block.settings.date != blank %}
                  <span class="cr-reviews__date">{{ block.settings.date }}</span>
                {% endif %}
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

<script>
  (function() {
    var section = document.querySelector('.cr-reviews[data-section-id="{{ section.id }}"]') || document.querySelector('.cr-reviews');
    var track = document.getElementById('cr-reviews-track-{{ section.id }}');
    var prevBtn = section && section.querySelector('.cr-reviews__arrow--prev');
    var nextBtn = section && section.querySelector('.cr-reviews__arrow--next');

    if (!track || !prevBtn || !nextBtn) return;

    function getCardWidth() {
      var card = track.querySelector('.cr-reviews__card');
      if (!card) return 320;
      return card.offsetWidth + 24;
    }

    prevBtn.addEventListener('click', function() {
      track.parentElement.scrollBy({ left: -getCardWidth(), behavior: 'smooth' });
    });

    nextBtn.addEventListener('click', function() {
      track.parentElement.scrollBy({ left: getCardWidth(), behavior: 'smooth' });
    });
  })();
</script>

<script>
  document.querySelectorAll('.cr-reviews__card').forEach(function(card) {
    var text = card.querySelector('.cr-reviews__text');
    var btn = card.querySelector('.cr-reviews__readmore');
    if (!text || !btn) return;

    function checkOverflow() {
      if (text.scrollHeight > text.clientHeight + 2) {
        btn.style.display = 'inline';
      } else {
        btn.style.display = 'none';
      }
    }

    btn.addEventListener('click', function() {
      var expanded = btn.getAttribute('aria-expanded') === 'true';
      if (expanded) {
        text.classList.remove('cr-reviews__text--expanded');
        btn.setAttribute('aria-expanded', 'false');
        btn.textContent = 'read more';
      } else {
        text.classList.add('cr-reviews__text--expanded');
        btn.setAttribute('aria-expanded', 'true');
        btn.textContent = 'show less';
      }
    });

    checkOverflow();
  });
</script>

{% stylesheet %}
.cr-reviews__heading-wrap {
  max-width: 1200px;
  margin-inline: auto;
  padding-inline: clamp(16px, 5vw, 80px);
  margin-bottom: 40px;
}

.cr-reviews__heading {
  font-size: 1.75rem;
  font-weight: 600;
  margin: 0;
  color: #111;
}

.cr-reviews__nav {
  max-width: 1200px;
  margin-inline: auto;
  padding-inline: clamp(16px, 5vw, 80px);
  display: flex;
  justify-content: flex-end;
  gap: 8px;
  margin-bottom: 20px;
}

.cr-reviews__arrow {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  border: 1px solid #d0d0d0;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  color: #333;
  transition: background 0.2s, border-color 0.2s, color 0.2s;
  flex-shrink: 0;
}

.cr-reviews__arrow:hover {
  background: #0f63bd;
  border-color: #0f63bd;
  color: #fff;
}

.cr-reviews__track-wrap {
  max-width: 1200px;
  margin-inline: auto;
  overflow-x: auto;
  overflow-y: visible;
  scrollbar-width: none;
  -webkit-overflow-scrolling: touch;
}

.cr-reviews__track-wrap::-webkit-scrollbar {
  display: none;
}

.cr-reviews__track {
  display: flex;
  gap: 24px;
  scroll-snap-type: x mandatory;
  padding-inline: clamp(16px, 5vw, 80px);
  padding-bottom: 8px;
  width: max-content;
}

.cr-reviews__card {
  display: flex;
  flex-direction: column;
  gap: 16px;
  padding: 28px;
  border: 1px solid #e8e8e8;
  border-radius: 8px;
  background: #fff;
  min-width: 320px;
  max-width: 360px;
  width: 340px;
  flex-shrink: 0;
  scroll-snap-align: start;
  box-sizing: border-box;
}

@media (max-width: 400px) {
  .cr-reviews__card {
    min-width: calc(100vw - 64px);
    width: calc(100vw - 64px);
    padding: 20px;
  }
}

.cr-reviews__stars {
  display: flex;
  gap: 2px;
}

.cr-reviews__star {
  font-size: 1rem;
  color: #ddd;
}

.cr-reviews__star--filled {
  color: #f5a623;
}

.cr-reviews__text-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.cr-reviews__text {
  font-size: 0.875rem;
  font-style: italic;
  color: #444;
  line-height: 1.7;
  margin: 0;
  display: -webkit-box;
  -webkit-line-clamp: 4;
  line-clamp: 4;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.cr-reviews__text--expanded {
  display: block;
  -webkit-line-clamp: unset;
  line-clamp: unset;
  overflow: visible;
}

.cr-reviews__readmore {
  background: none;
  border: none;
  padding: 0;
  font-size: 0.8rem;
  color: #4a7cf5;
  cursor: pointer;
  text-align: left;
  text-decoration: underline;
  display: none;
}

.cr-reviews__readmore:hover {
  color: #0f63bd;
}

.cr-reviews__quote {
  color: #4a7cf5;
  font-size: 1.2rem;
  font-style: normal;
  font-weight: 700;
}

.cr-reviews__author {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-top: auto;
}

.cr-reviews__avatar {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  overflow: hidden;
  background: #4a7cf5;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.cr-reviews__avatar span {
  color: #fff;
  font-size: 1rem;
  font-weight: 600;
}

.cr-reviews__avatar img {
  width: 40px;
  height: 40px;
  object-fit: cover;
}

.cr-reviews__author-info {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.cr-reviews__author-name {
  font-size: 0.875rem;
  font-weight: 600;
  color: #111;
}

.cr-reviews__date {
  font-size: 0.75rem;
  color: #999;
}
{% endstylesheet %}

{% schema %}
{
  "name": "Car Rental Reviews",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What our customers say"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f9f9f9"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "label": "Rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Review text",
          "default": "Excellent service! The driver was professional and on time."
        },
        {
          "type": "image_picker",
          "id": "avatar",
          "label": "Author photo"
        },
        {
          "type": "text",
          "id": "author_name",
          "label": "Author name",
          "default": "John Smith"
        },
        {
          "type": "text",
          "id": "date",
          "label": "Date",
          "default": "2024-01-15"
        }
      ]
    }
  ],
  "presets": [
