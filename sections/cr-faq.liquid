<div class="cr-faq" style="background: {{ section.settings.background_color }}; padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;">
  <div class="cr-faq__inner">
    <div class="cr-faq__content">
      {% if section.settings.heading != blank %}
        <h2 class="cr-faq__heading">{{ section.settings.heading }}</h2>
      {% endif %}
      <div class="cr-faq__list">
        {% for block in section.blocks %}
          {% if block.type == 'item' %}
            <details class="cr-faq__item" {{ block.shopify_attributes }}>
              <summary class="cr-faq__question">
                {{ block.settings.question }}
                <svg class="cr-faq__icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </summary>
              <div class="cr-faq__answer">
                <p>{{ block.settings.answer }}</p>
              </div>
            </details>
          {% endif %}
        {% endfor %}
      </div>
    </div>
    <div class="cr-faq__media">
      {% if section.settings.image != blank %}
        {{ section.settings.image | image_url: width: 700 | image_tag: width: 700, loading: 'lazy', class: 'cr-faq__image' }}
      {% else %}
        <div class="cr-faq__placeholder"></div>
      {% endif %}
    </div>
  </div>
</div>

{% stylesheet %}
.cr-faq__inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  align-items: start;
  max-width: 1200px;
  margin-inline: auto;
  padding-inline: clamp(16px, 5vw, 80px);
}

.cr-faq__heading {
  font-size: clamp(1.375rem, 2.5vw, 1.875rem);
  font-weight: 600;
  margin: 0 0 28px;
  color: #111;
}

.cr-faq__list {
  display: flex;
  flex-direction: column;
  gap: 0;
  border-top: 1px solid #e8e8e8;
}

.cr-faq__item {
  border-bottom: 1px solid #e8e8e8;
}

.cr-faq__question {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16px;
  padding: 18px 0;
  font-size: 0.9rem;
  font-weight: 500;
  color: #111;
  cursor: pointer;
  list-style: none;
  user-select: none;
}

.cr-faq__question::-webkit-details-marker {
  display: none;
}

.cr-faq__icon {
  flex-shrink: 0;
  transition: transform 0.25s ease;
  color: #555;
}

details[open] .cr-faq__icon {
  transform: rotate(180deg);
}

details[open] .cr-faq__question {
  color: #0f63bd;
}

.cr-faq__answer {
  padding: 0 0 18px;
}

.cr-faq__answer p {
  font-size: 0.875rem;
  color: #555;
  line-height: 1.75;
  margin: 0;
}

.cr-faq__image {
  width: 100%;
  height: auto;
  display: block;
  border-radius: 8px;
  position: sticky;
  top: 24px;
}

.cr-faq__placeholder {
  width: 100%;
  aspect-ratio: 3/4;
  background: #e8e8e8;
  border-radius: 8px;
}

@media (max-width: 768px) {
  .cr-faq__inner {
    grid-template-columns: 1fr;
  }

  .cr-faq__media {
    display: none;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "FAQ",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "FAQ item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "What does an airport transfer do?"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "default": "An airport transfer is a pre-booked vehicle service that takes you to or from the airport safely and on time."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        { "type": "item", "settings": { "question": "What does an airport transfer do?", "answer": "An airport transfer is a pre-booked vehicle service that takes you to or from the airport safely and on time." } },
        { "type": "item", "settings": { "question": "Is it worth booking an airport transfer?", "answer": "Yes — a pre-booked transfer removes the stress of finding transport after a long flight and ensures you arrive on time." } },
        { "type": "item", "settings": { "question": "What is a paid airport transfer?", "answer": "A paid airport transfer is a ride with a pre-booked professional driver to take customers to and/or from the airport." } }
      ]
    }
  ]
}
{% endschema %}
