<div class="cr-text-image" style="background: {{ section.settings.background_color }}; padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;">
  <div class="cr-text-image__inner {% if section.settings.image_position == 'left' %}cr-text-image__inner--reverse{% endif %}">
    <div class="cr-text-image__content">
      {% if section.settings.heading != blank %}
        <h2 class="cr-text-image__heading">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.text != blank %}
        <div class="cr-text-image__text">{{ section.settings.text }}</div>
      {% endif %}
      {% if section.settings.button_label != blank and section.settings.button_link != blank %}
        <a class="cr-text-image__btn" href="{{ section.settings.button_link }}">{{ section.settings.button_label }}</a>
      {% endif %}
    </div>
    <div class="cr-text-image__media">
      {% if section.settings.image != blank %}
        {{ section.settings.image | image_url: width: 800 | image_tag: width: 800, loading: 'lazy', class: 'cr-text-image__image' }}
      {% else %}
        <div class="cr-text-image__placeholder"></div>
      {% endif %}
    </div>
  </div>
</div>

{% stylesheet %}
.cr-text-image__inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  align-items: center;
  max-width: 1200px;
  margin-inline: auto;
  padding-inline: clamp(16px, 5vw, 80px);
}

.cr-text-image__inner--reverse {
  direction: rtl;
}

.cr-text-image__inner--reverse > * {
  direction: ltr;
}

.cr-text-image__content {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.cr-text-image__heading {
  font-size: clamp(1.375rem, 2.5vw, 1.875rem);
  font-weight: 600;
  margin: 0;
  color: #111;
  line-height: 1.25;
}

.cr-text-image__text {
  font-size: 0.9rem;
  color: #555;
  line-height: 1.75;
}

.cr-text-image__text a {
  color: #0f63bd;
}

.cr-text-image__btn {
  display: inline-block;
  padding: 12px 24px;
  background: #0f63bd;
  color: #fff;
  text-decoration: none;
  border-radius: 4px;
  font-size: 0.875rem;
  font-weight: 600;
  transition: background 0.2s;
  align-self: flex-start;
}

.cr-text-image__btn:hover {
  background: #0a4f99;
}

.cr-text-image__image {
  width: 100%;
  height: auto;
  display: block;
  border-radius: 8px;
  object-fit: cover;
}

.cr-text-image__placeholder {
  width: 100%;
  aspect-ratio: 4/3;
  background: #e8e8e8;
  border-radius: 8px;
}

@media (max-width: 768px) {
  .cr-text-image__inner {
    grid-template-columns: 1fr;
    direction: ltr;
    gap: 32px;
  }

  .cr-text-image__inner--reverse .cr-text-image__media {
    order: -1;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Text + Image",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Airport transfer in global cities"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "options": [
        { "value": "right", "label": "Right (text left)" },
        { "value": "left", "label": "Left (text right)" }
      ],
      "default": "right"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Text + Image"
    }
  ]
}
{% endschema %}
