<section class="cr-th">
  <div class="cr-th__bg">
    {% if section.settings.image != blank %}
      {{ section.settings.image | image_url: width: 1600 | image_tag: width: 1600, loading: 'eager', class: 'cr-th__bg-image' }}
    {% else %}
      <div class="cr-th__bg-placeholder"></div>
    {% endif %}
    <div class="cr-th__overlay"></div>
  </div>

  <div class="cr-th__inner">
    <div class="cr-th__left">
      {% if section.settings.heading != blank %}
        <h1 class="cr-th__heading">{{ section.settings.heading }}</h1>
      {% endif %}
    </div>

    <div class="cr-th__right">
      <div class="cr-th__card">
        <div class="cr-th__tabs">
          <button class="cr-th__tab cr-th__tab--active" data-target="one-way">One way</button>
          <button class="cr-th__tab" data-target="by-hour">By the hour</button>
        </div>

        <form class="cr-th__form" action="{{ section.settings.form_action }}" method="get">
          <div class="cr-th__field">
            <span class="cr-th__field-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#999" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="10" r="3"/><path d="M12 2a8 8 0 0 0-8 8c0 5.25 8 13 8 13s8-7.75 8-13a8 8 0 0 0-8-8z"/></svg>
            </span>
            <input class="cr-th__input" type="text" name="from" placeholder="{{ section.settings.placeholder_from | default: 'Address, airport, hotel, …' }}" autocomplete="off">
          </div>

          <div class="cr-th__field cr-th__field--one-way" style="display:none;">
            <span class="cr-th__field-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#999" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="10" r="3"/><path d="M12 2a8 8 0 0 0-8 8c0 5.25 8 13 8 13s8-7.75 8-13a8 8 0 0 0-8-8z"/></svg>
            </span>
            <input class="cr-th__input" type="text" name="to" placeholder="{{ section.settings.placeholder_to | default: 'Address, airport, hotel, …' }}" autocomplete="off">
          </div>

          <div class="cr-th__field cr-th__field--by-hour" style="display:none;">
            <span class="cr-th__field-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#999" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </span>
            <select class="cr-th__input cr-th__select" name="duration">
              <option>1 hour</option>
              <option selected>2 hours</option>
              <option>3 hours</option>
              <option>4 hours</option>
              <option>6 hours</option>
              <option>8 hours</option>
              <option>10 hours</option>
              <option>12 hours</option>
              <option>Full day</option>
            </select>
          </div>

          <div class="cr-th__field">
            <span class="cr-th__field-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#999" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            </span>
            <input class="cr-th__input" type="date" name="date">
          </div>

          <div class="cr-th__field">
            <span class="cr-th__field-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#999" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </span>
            <input class="cr-th__input" type="time" name="time" value="13:10">
          </div>

          <button type="submit" class="cr-th__submit">
            {{ section.settings.button_label | default: 'Search' }}
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  (function() {
    var tabs = document.querySelectorAll('.cr-th__tab');
    if (!tabs.length) return;

    tabs.forEach(function(tab) {
      tab.addEventListener('click', function() {
        tabs.forEach(function(t) { t.classList.remove('cr-th__tab--active'); });
        tab.classList.add('cr-th__tab--active');

        var target = tab.getAttribute('data-target');
        var oneWayFields = document.querySelectorAll('.cr-th__field--one-way');
        var byHourFields = document.querySelectorAll('.cr-th__field--by-hour');

        if (target === 'one-way') {
          oneWayFields.forEach(function(f) { f.style.display = 'flex'; });
          byHourFields.forEach(function(f) { f.style.display = 'none'; });
        } else {
          oneWayFields.forEach(function(f) { f.style.display = 'none'; });
          byHourFields.forEach(function(f) { f.style.display = 'flex'; });
        }
      });
    });

    var dateInput = document.querySelector('.cr-th__form input[type="date"]');
    if (dateInput && !dateInput.value) {
      var today = new Date();
      var yyyy = today.getFullYear();
      var mm = String(today.getMonth() + 1).padStart(2, '0');
      var dd = String(today.getDate()).padStart(2, '0');
      dateInput.value = yyyy + '-' + mm + '-' + dd;
    }
  })();
</script>

{% stylesheet %}
.cr-th {
  position: relative;
  min-height: 560px;
  display: flex;
  align-items: center;
  overflow: hidden;
  padding-block: clamp(48px, 8vw, 96px);
}

.cr-th__bg {
  position: absolute;
  inset: 0;
  z-index: 0;
}

.cr-th__bg-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.cr-th__bg-placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #1a3a5c 0%, #0f2240 100%);
}

.cr-th__overlay {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.48);
}

.cr-th__inner {
  position: relative;
  z-index: 1;
  width: 100%;
  max-width: 1200px;
  margin-inline: auto;
  padding-inline: clamp(16px, 5vw, 80px);
  display: grid;
  grid-template-columns: 1fr 380px;
  gap: 48px;
  align-items: center;
}

.cr-th__left {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.cr-th__heading {
  font-size: clamp(1.875rem, 4.5vw, 3rem);
  font-weight: 700;
  line-height: 1.15;
  color: #ffffff;
  margin: 0;
  max-width: 500px;
  text-shadow: 0 2px 12px rgba(0,0,0,0.3);
}

.cr-th__card {
  background: #fff;
  border-radius: 12px;
  box-shadow: 0 8px 40px rgba(0,0,0,0.22);
  overflow: hidden;
}

.cr-th__tabs {
  display: grid;
  grid-template-columns: 1fr 1fr;
  border-bottom: 1px solid #e0e0e0;
}

.cr-th__tab {
  padding: 14px 12px;
  font-size: 0.875rem;
  font-weight: 600;
  color: #666;
  background: none;
  border: none;
  cursor: pointer;
  transition: color 0.2s, background 0.2s;
}

.cr-th__tab--active {
  color: #111;
  background: #f8f8f8;
  border-bottom: 2px solid #0f63bd;
}

.cr-th__tab:not(.cr-th__tab--active):hover {
  background: #fafafa;
}

.cr-th__form {
  display: flex;
  flex-direction: column;
  gap: 0;
  padding: 0;
}

.cr-th__field {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 13px 16px;
  border-bottom: 1px solid #ebebeb;
  background: #f6f6f6;
  transition: background 0.15s;
}

.cr-th__field:last-of-type {
  border-bottom: none;
}

.cr-th__field:focus-within {
  background: #efefef;
}

.cr-th__field-icon {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  color: #aaa;
}

.cr-th__input {
  flex: 1;
  border: none;
  outline: none;
  font-size: 0.875rem;
  color: #111;
  background: transparent;
  font-family: inherit;
}

.cr-th__input::placeholder {
  color: #aaa;
}

.cr-th__select {
  appearance: none;
  -webkit-appearance: none;
  cursor: pointer;
  color: #111;
}

.cr-th__submit {
  margin: 16px;
  padding: 14px;
  background: #0f63bd;
  color: #fff;
  border: none;
  border-radius: 6px;
  font-size: 0.9375rem;
  font-weight: 600;
  cursor: pointer;
  transition: background 0.2s;
  width: calc(100% - 32px);
}

.cr-th__submit:hover {
  background: #0a4f99;
}

@media (max-width: 900px) {
  .cr-th__inner {
    grid-template-columns: 1fr;
    gap: 32px;
  }

  .cr-th__heading {
    max-width: 100%;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Transfer Hero",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Airport & City Transfers"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image"
    },
    {
      "type": "text",
      "id": "placeholder_from",
      "label": "From field placeholder",
      "default": "Address, airport, hotel, …"
    },
    {
      "type": "text",
      "id": "placeholder_to",
      "label": "To field placeholder",
      "default": "Address, airport, hotel, …"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Search"
    },
    {
      "type": "url",
      "id": "form_action",
      "label": "Form submit URL"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Transfer Hero"
    }
  ]
}
{% endschema %}
