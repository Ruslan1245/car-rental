<footer class="cr-footer" style="background: {{ section.settings.background_color }};">
  <div class="cr-footer__inner">

    <div class="cr-footer__top">
      <span class="cr-footer__brand">{{ section.settings.brand_name }}</span>
      <div class="cr-footer__badges">
        <a class="cr-footer__badge-link" {% if section.settings.appstore_link != blank %}href="{{ section.settings.appstore_link }}"{% else %}href="#"{% endif %} target="_blank" rel="noopener">
          {% if section.settings.appstore_badge != blank %}
            {{ section.settings.appstore_badge | image_url: width: 270 | image_tag: width: 120, loading: 'lazy' }}
          {% else %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 120 40" width="120" height="40">
              <rect width="120" height="40" rx="8" fill="#1a1a1a"/>
              <path d="M24.77 19.88a5.26 5.26 0 0 1 2.5-4.41 5.39 5.39 0 0 0-4.24-2.3c-1.79-.19-3.52 1.07-4.43 1.07-.93 0-2.33-1.05-3.84-1.02a5.65 5.65 0 0 0-4.76 2.9c-2.06 3.56-.52 8.79 1.45 11.67.99 1.41 2.14 2.99 3.65 2.93 1.48-.06 2.03-.94 3.82-.94 1.77 0 2.28.94 3.83.91 1.59-.03 2.58-1.42 3.54-2.84a11.6 11.6 0 0 0 1.62-3.29 5.08 5.08 0 0 1-3.14-4.68z" fill="#fff"/>
              <path d="M21.86 11.37a5.18 5.18 0 0 0 1.18-3.71 5.27 5.27 0 0 0-3.41 1.76 4.93 4.93 0 0 0-1.22 3.57 4.36 4.36 0 0 0 3.45-1.62z" fill="#fff"/>
              <text x="38" y="16" font-family="Arial,sans-serif" font-size="8" fill="#fff" opacity="0.8">Download on the</text>
              <text x="38" y="29" font-family="Arial,sans-serif" font-size="13" font-weight="bold" fill="#fff">App Store</text>
            </svg>
          {% endif %}
        </a>
        <a class="cr-footer__badge-link" {% if section.settings.googleplay_link != blank %}href="{{ section.settings.googleplay_link }}"{% else %}href="#"{% endif %} target="_blank" rel="noopener">
          {% if section.settings.googleplay_badge != blank %}
            {{ section.settings.googleplay_badge | image_url: width: 270 | image_tag: width: 120, loading: 'lazy' }}
          {% else %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 120 40" width="120" height="40">
              <rect width="120" height="40" rx="8" fill="#1a1a1a"/>
              <text x="16" y="16" font-family="Arial,sans-serif" font-size="8" fill="#fff" opacity="0.8">GET IT ON</text>
              <text x="16" y="29" font-family="Arial,sans-serif" font-size="13" font-weight="bold" fill="#fff">Google Play</text>
            </svg>
          {% endif %}
        </a>
      </div>
    </div>

    <div class="cr-footer__nav">
      {% for block in section.blocks %}
        {% if block.type == 'column' %}
          <div class="cr-footer__col" {{ block.shopify_attributes }}>
            {% if block.settings.heading != blank %}
              <h4 class="cr-footer__col-heading">{{ block.settings.heading }}</h4>
            {% endif %}
            {% if block.settings.menu != blank %}
              {% assign nav = linklists[block.settings.menu] %}
              {% if nav %}
                <ul class="cr-footer__links">
                  {% for link in nav.links %}
                    <li><a class="cr-footer__link" href="{{ link.url }}">{{ link.title }}</a></li>
                  {% endfor %}
                </ul>
              {% endif %}
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <div class="cr-footer__bottom">
      <span class="cr-footer__copy">{{ section.settings.copyright }}</span>
      <div class="cr-footer__legal">
        {% if section.settings.terms_link != blank %}<a href="{{ section.settings.terms_link }}">Terms</a>{% endif %}
        {% if section.settings.privacy_link != blank %}<a href="{{ section.settings.privacy_link }}">Privacy policy</a>{% endif %}
        {% if section.settings.legal_link != blank %}<a href="{{ section.settings.legal_link }}">Legal notice</a>{% endif %}
      </div>
      <div class="cr-footer__social">
        {% if section.settings.social_linkedin != blank %}
          <a href="{{ section.settings.social_linkedin }}" target="_blank" rel="noopener" aria-label="LinkedIn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
          </a>
        {% endif %}
        {% if section.settings.social_instagram != blank %}
          <a href="{{ section.settings.social_instagram }}" target="_blank" rel="noopener" aria-label="Instagram">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
          </a>
        {% endif %}
        {% if section.settings.social_facebook != blank %}
          <a href="{{ section.settings.social_facebook }}" target="_blank" rel="noopener" aria-label="Facebook">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
        {% endif %}
        {% if section.settings.social_youtube != blank %}
          <a href="{{ section.settings.social_youtube }}" target="_blank" rel="noopener" aria-label="YouTube">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 0 0 1.46 6.42 29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58 2.78 2.78 0 0 0 1.95 1.96C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.96-1.96A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" fill="#1a1a1a"/></svg>
          </a>
        {% endif %}
        {% if section.settings.social_x != blank %}
          <a href="{{ section.settings.social_x }}" target="_blank" rel="noopener" aria-label="X">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
        {% endif %}
      </div>
    </div>

  </div>
</footer>

{% stylesheet %}
.cr-footer {
  border-top: 1px solid #e8e8e8;
}

.cr-footer__inner {
  max-width: 1200px;
  margin-inline: auto;
  padding: 48px clamp(16px, 5vw, 80px) 32px;
  display: flex;
  flex-direction: column;
  gap: 40px;
}

.cr-footer__top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 16px;
}

.cr-footer__brand {
  font-size: 1.25rem;
  font-weight: 700;
  color: #111;
  letter-spacing: -0.01em;
}

.cr-footer__badges {
  display: flex;
  gap: 10px;
  align-items: center;
}

.cr-footer__badge-link {
  display: inline-block;
  opacity: 1;
  transition: opacity 0.2s;
}

.cr-footer__badge-link:hover {
  opacity: 0.8;
}

.cr-footer__nav {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 24px;
}

.cr-footer__col-heading {
  font-size: 0.8rem;
  font-weight: 700;
  color: #111;
  margin: 0 0 16px;
  text-transform: none;
}

.cr-footer__links {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.cr-footer__link {
  font-size: 0.8rem;
  color: #555;
  text-decoration: none;
  transition: color 0.2s;
}

.cr-footer__link:hover {
  color: #111;
}

.cr-footer__bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 16px;
  padding-top: 24px;
  border-top: 1px solid #e0d9d0;
}

.cr-footer__copy {
  font-size: 0.75rem;
  color: #888;
}

.cr-footer__legal {
  display: flex;
  gap: 20px;
  flex-wrap: wrap;
}

.cr-footer__legal a {
  font-size: 0.75rem;
  color: #555;
  text-decoration: none;
}

.cr-footer__legal a:hover {
  color: #111;
}

.cr-footer__social {
  display: flex;
  gap: 16px;
  align-items: center;
}

.cr-footer__social a {
  color: #555;
  text-decoration: none;
  display: flex;
  align-items: center;
  transition: color 0.2s;
}

.cr-footer__social a:hover {
  color: #111;
}

@media (max-width: 900px) {
  .cr-footer__nav {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 600px) {
  .cr-footer__nav {
    grid-template-columns: 1fr;
  }

  .cr-footer__bottom {
    flex-direction: column;
    align-items: flex-start;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Car Rental Footer",
  "tag": "section",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#EAF3FB"
    },
    {
      "type": "text",
      "id": "brand_name",
      "label": "Brand name",
      "default": "Car rental"
    },
    {
      "type": "image_picker",
      "id": "appstore_badge",
      "label": "App Store badge image"
    },
    {
      "type": "url",
      "id": "appstore_link",
      "label": "App Store link"
    },
    {
      "type": "image_picker",
      "id": "googleplay_badge",
      "label": "Google Play badge image"
    },
    {
      "type": "url",
      "id": "googleplay_link",
      "label": "Google Play link"
    },
    {
      "type": "text",
      "id": "copyright",
      "label": "Copyright text",
      "default": "©2026 Car Rental"
    },
    {
      "type": "url",
      "id": "terms_link",
      "label": "Terms link"
    },
    {
      "type": "url",
      "id": "privacy_link",
      "label": "Privacy policy link"
    },
    {
      "type": "url",
      "id": "legal_link",
      "label": "Legal notice link"
    },
    {
      "type": "header",
      "content": "Social media"
    },
    {
      "type": "url",
      "id": "social_linkedin",
      "label": "LinkedIn URL"
    },
    {
      "type": "url",
      "id": "social_instagram",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "social_facebook",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "social_youtube",
      "label": "YouTube URL"
    },
    {
      "type": "url",
      "id": "social_x",
      "label": "X (Twitter) URL"
    }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Navigation column",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Column heading",
          "default": "Company"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Navigation menu"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Car Rental Footer",
      "blocks": [
        { "type": "column", "settings": { "heading": "Company" } },
        { "type": "column", "settings": { "heading": "For Business" } },
        { "type": "column", "settings": { "heading": "Top cities" } },
        { "type": "column", "settings": { "heading": "Explore" } },
        { "type": "column", "settings": { "heading": "City-to-City rides" } }
      ]
    }
  ]
}
{% endschema %}
