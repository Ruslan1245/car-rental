<div class="cr-app" style="background: {{ section.settings.background_color }}; padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;">
  <div class="cr-app__inner">
    <div class="cr-app__content">
      {% if section.settings.heading != blank %}
        <h2 class="cr-app__heading">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <p class="cr-app__subheading">{{ section.settings.subheading }}</p>
      {% endif %}
      <div class="cr-app__buttons">
        {% if section.settings.appstore_link != blank %}
          <a class="cr-app__store-btn" href="{{ section.settings.appstore_link }}" target="_blank" rel="noopener">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 120 40" width="135" height="40">
              <rect width="120" height="40" rx="8" fill="#000"/>
              <path d="M24.77 19.88a5.26 5.26 0 0 1 2.5-4.41 5.39 5.39 0 0 0-4.24-2.3c-1.79-.19-3.52 1.07-4.43 1.07-.93 0-2.33-1.05-3.84-1.02a5.65 5.65 0 0 0-4.76 2.9c-2.06 3.56-.52 8.79 1.45 11.67.99 1.41 2.14 2.99 3.65 2.93 1.48-.06 2.03-.94 3.82-.94 1.77 0 2.28.94 3.83.91 1.59-.03 2.58-1.42 3.54-2.84a11.6 11.6 0 0 0 1.62-3.29 5.08 5.08 0 0 1-3.14-4.68z" fill="#fff"/>
              <path d="M21.86 11.37a5.18 5.18 0 0 0 1.18-3.71 5.27 5.27 0 0 0-3.41 1.76 4.93 4.93 0 0 0-1.22 3.57 4.36 4.36 0 0 0 3.45-1.62z" fill="#fff"/>
              <text x="38" y="16" font-family="Arial,sans-serif" font-size="8" fill="#fff" opacity="0.8">Download on the</text>
              <text x="38" y="29" font-family="Arial,sans-serif" font-size="14" font-weight="bold" fill="#fff">App Store</text>
            </svg>
          </a>
        {% endif %}
        {% if section.settings.googleplay_link != blank %}
          <a class="cr-app__store-btn" href="{{ section.settings.googleplay_link }}" target="_blank" rel="noopener">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 120 40" width="135" height="40">
              <rect width="120" height="40" rx="8" fill="#000"/>
              <path d="M12 8.5l14.5 11.5-14.5 11.5V8.5z" fill="url(#gp1)"/>
              <path d="M12 8.5l8.5 8.5-8.5 8.5L7 20.5l5-12z" fill="url(#gp2)"/>
              <path d="M26.5 20l4 2.5-18 10.5 14-13z" fill="url(#gp3)"/>
              <path d="M26.5 20l4-2.5-18-9.5 14 12z" fill="url(#gp4)"/>
              <defs>
                <linearGradient id="gp1" x1="0%" y1="0%" x2="100%" y2="0%"><stop offset="0%" stop-color="#00C6FF"/><stop offset="100%" stop-color="#00A6FF"/></linearGradient>
                <linearGradient id="gp2" x1="0%" y1="0%" x2="0%" y2="100%"><stop offset="0%" stop-color="#00F076"/><stop offset="100%" stop-color="#00C853"/></linearGradient>
                <linearGradient id="gp3" x1="0%" y1="0%" x2="100%" y2="0%"><stop offset="0%" stop-color="#FF6D00"/><stop offset="100%" stop-color="#FFAB00"/></linearGradient>
                <linearGradient id="gp4" x1="0%" y1="0%" x2="100%" y2="0%"><stop offset="0%" stop-color="#FF1744"/><stop offset="100%" stop-color="#FF4081"/></linearGradient>
              </defs>
              <text x="38" y="16" font-family="Arial,sans-serif" font-size="8" fill="#fff" opacity="0.8">GET IT ON</text>
              <text x="38" y="29" font-family="Arial,sans-serif" font-size="14" font-weight="bold" fill="#fff">Google Play</text>
            </svg>
          </a>
        {% endif %}
      </div>
    </div>
    <div class="cr-app__media">
      {% if section.settings.screenshot != blank %}
        {{ section.settings.screenshot | image_url: width: 700 | image_tag: width: 700, loading: 'lazy', class: 'cr-app__screenshot' }}
      {% else %}
        <div class="cr-app__screenshot-placeholder"></div>
      {% endif %}
    </div>
  </div>
</div>

{% stylesheet %}
.cr-app__inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: center;
  gap: 48px;
  max-width: 1200px;
  margin-inline: auto;
  padding-inline: clamp(16px, 5vw, 80px);
}

.cr-app__content {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.cr-app__heading {
  font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 700;
  line-height: 1.15;
  margin: 0;
  color: #111;
}

.cr-app__subheading {
  font-size: 1rem;
  font-weight: 500;
  color: #333;
  line-height: 1.5;
  margin: 0;
  max-width: 380px;
}

.cr-app__buttons {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
}

.cr-app__store-btn {
  display: inline-block;
  text-decoration: none;
  opacity: 1;
  transition: opacity 0.2s;
}

.cr-app__store-btn:hover {
  opacity: 0.85;
}

.cr-app__screenshot {
  width: 100%;
  height: auto;
  display: block;
  border-radius: 8px;
}

.cr-app__screenshot-placeholder {
  width: 100%;
  height: 300px;
  background: rgba(0,0,0,0.08);
  border-radius: 8px;
}

@media (max-width: 768px) {
  .cr-app__inner {
    grid-template-columns: 1fr;
  }

  .cr-app__media {
    order: -1;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "App Promo",
  "tag": "section",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#d6e8f7"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "We move with you."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Have all your journeys in the palm of your hand with our app."
    },
    {
      "type": "url",
      "id": "appstore_link",
      "label": "App Store link"
    },
    {
      "type": "url",
      "id": "googleplay_link",
      "label": "Google Play link"
    },
    {
      "type": "image_picker",
      "id": "screenshot",
      "label": "App screenshot image"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "App Promo"
    }
  ]
}
{% endschema %}
