<div class="cr-tailored" style="background: {{ section.settings.background_color }}; padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;">
  <div class="cr-tailored__inner">
    {% if section.settings.heading != blank %}
      <h2 class="cr-tailored__heading" style="color: {{ section.settings.heading_color }};">{{ section.settings.heading }}</h2>
    {% endif %}
    <div class="cr-tailored__grid">
      {% for block in section.blocks %}
        {% if block.type == 'item' %}
          <div class="cr-tailored__item" {{ block.shopify_attributes }}>
            {% if block.settings.image != blank %}
              <div class="cr-tailored__image-wrap">
                {{ block.settings.image | image_url: width: 600 | image_tag: width: 600, loading: 'lazy', class: 'cr-tailored__image' }}
              </div>
            {% else %}
              <div class="cr-tailored__image-placeholder"></div>
            {% endif %}
            <div class="cr-tailored__content">
              {% if block.settings.title != blank %}
                <h3 class="cr-tailored__title">{{ block.settings.title }}</h3>
              {% endif %}
              {% if block.settings.description != blank %}
                <p class="cr-tailored__desc">{{ block.settings.description }}</p>
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

{% stylesheet %}
.cr-tailored__inner {
  max-width: 1200px;
  margin-inline: auto;
  padding-inline: clamp(16px, 5vw, 80px);
}

.cr-tailored__heading {
  font-size: clamp(1.5rem, 3vw, 2.25rem);
  font-weight: 600;
  text-align: center;
  margin: 0 0 40px;
  font-style: normal;
}

.cr-tailored__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 32px;
}

.cr-tailored__item {
  background: #deeef9;
  border: 1px solid #aacde8;
  border-radius: 12px;
  overflow: hidden;
}

.cr-tailored__image-wrap {
  overflow: hidden;
  aspect-ratio: 4/3;
}

.cr-tailored__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.4s ease;
}

.cr-tailored__image-wrap:hover .cr-tailored__image {
  transform: scale(1.03);
}

.cr-tailored__image-placeholder {
  aspect-ratio: 4/3;
  background: #c2ddf0;
}

.cr-tailored__content {
  padding: 20px 20px 24px;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.cr-tailored__title {
  font-size: 1rem;
  font-weight: 600;
  margin: 0;
  color: #111;
}

.cr-tailored__desc {
  font-size: 0.875rem;
  color: #111;
  line-height: 1.6;
  margin: 0;
}

@media (max-width: 768px) {
  .cr-tailored__grid {
    grid-template-columns: 1fr;
    gap: 24px;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Tailored To You",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Tailored to you"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#7a9cbf"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f5f0ea"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Card",
      "limit": 6,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Corporate travel"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Arrange business journeys for your employees, clients, or yourself with ease."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Tailored To You",
      "blocks": [
        { "type": "item", "settings": { "title": "Corporate travel", "description": "Arrange business journeys for your employees, clients, or yourself with ease." } },
        { "type": "item", "settings": { "title": "Travel agencies", "description": "Earn more with a top-tier travel provider, integrated in your GDS." } },
        { "type": "item", "settings": { "title": "Strategic partnerships", "description": "Gift your valuable customers our services via a bespoke business solution." } }
      ]
    }
  ]
}
{% endschema %}
