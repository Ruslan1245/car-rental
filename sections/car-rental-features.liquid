<div class="cr-features" style="background: {{ section.settings.background_color }}; padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;">
  {% if section.settings.heading != blank %}
    <div class="cr-features__heading-wrap">
      <h2 class="cr-features__heading" style="color: {{ section.settings.heading_color }};">{{ section.settings.heading }}</h2>
    </div>
  {% endif %}
  <div class="cr-features__grid page-width-normal">
    {% for block in section.blocks %}
      {% if block.type == 'feature' %}
        <div class="cr-features__item" {{ block.shopify_attributes }}>
          <div class="cr-features__icon">
            {% case block.settings.icon_type %}
              {% when 'globe' %}
                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#4a7cf5" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10"/>
                  <line x1="2" y1="12" x2="22" y2="12"/>
                  <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
                </svg>
              {% when 'sync' %}
                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#4a7cf5" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="23 4 23 10 17 10"/>
                  <polyline points="1 20 1 14 7 14"/>
                  <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/>
                </svg>
              {% when 'clock' %}
                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#4a7cf5" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10"/>
                  <polyline points="12 6 12 12 16 14"/>
                </svg>
              {% when 'headphones' %}
                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#4a7cf5" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M3 18v-6a9 9 0 0 1 18 0v6"/>
                  <path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3z"/>
                  <path d="M3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"/>
                </svg>
              {% when 'list' %}
                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#4a7cf5" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="8" y1="6" x2="21" y2="6"/>
                  <line x1="8" y1="12" x2="21" y2="12"/>
                  <line x1="8" y1="18" x2="21" y2="18"/>
                  <circle cx="3" cy="6" r="1" fill="#4a7cf5" stroke="none"/>
                  <circle cx="3" cy="12" r="1" fill="#4a7cf5" stroke="none"/>
                  <circle cx="3" cy="18" r="1" fill="#4a7cf5" stroke="none"/>
                </svg>
              {% when 'cloud' %}
                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#4a7cf5" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"/>
                </svg>
              {% when 'rates' %}
                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#4a7cf5" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2" y="5" width="20" height="14" rx="2"/>
                  <line x1="2" y1="10" x2="22" y2="10"/>
                </svg>
              {% when 'car' %}
                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#4a7cf5" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 17H3a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v9a2 2 0 0 1-2 2h-2"/>
                  <circle cx="7" cy="17" r="2"/>
                  <circle cx="17" cy="17" r="2"/>
                </svg>
            {% endcase %}
          </div>
          <h3 class="cr-features__title">{{ block.settings.title }}</h3>
          <p class="cr-features__description">{{ block.settings.description }}</p>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</div>

{% stylesheet %}
.cr-features__heading-wrap {
  max-width: 1200px;
  margin-inline: auto;
  padding-inline: clamp(16px, 5vw, 80px);
  margin-bottom: 40px;
  text-align: center;
}

.cr-features__heading {
  font-size: clamp(1.5rem, 3vw, 2.25rem);
  font-weight: 600;
  margin: 0;
  font-style: normal;
}

.cr-features__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
  max-width: 1200px;
  margin-inline: auto;
  padding-inline: clamp(16px, 5vw, 80px);
}

.cr-features__item {
  display: flex;
  flex-direction: column;
  gap: 12px;
  border: 1px solid #e0e0e0;
  border-radius: 14px;
  padding: 28px 24px;
  background: #ffffff;
}

.cr-features__icon {
  width: 48px;
  height: 48px;
}

.cr-features__title {
  font-size: 1rem;
  font-weight: 600;
  margin: 0;
  color: #111;
}

.cr-features__description {
  font-size: 0.875rem;
  color: #111;
  line-height: 1.6;
  margin: 0;
}

@media (max-width: 768px) {
  .cr-features__grid {
    grid-template-columns: 1fr;
    gap: 32px;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Car Rental Features",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#7a9cbf"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature item",
      "limit": 6,
      "settings": [
        {
          "type": "select",
          "id": "icon_type",
          "label": "Icon",
          "options": [
            { "value": "globe", "label": "Globe / Global" },
            { "value": "sync", "label": "Sync / Refresh" },
            { "value": "clock", "label": "Clock / Time" },
            { "value": "headphones", "label": "Headphones / Support" },
            { "value": "list", "label": "List / Management" },
            { "value": "cloud", "label": "Cloud / Sustainability" },
            { "value": "rates", "label": "Card / Rates" },
            { "value": "car", "label": "Car" }
          ],
          "default": "globe"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Feature title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Describe this feature in a few words."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Car Rental Features"
    }
  ]
}
{% endschema %}
