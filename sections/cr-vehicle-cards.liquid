<div class="cr-vehicles" style="background: {{ section.settings.background_color }}; padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;">
  <div class="cr-vehicles__inner">
    {% if section.settings.heading != blank %}
      <h2 class="cr-vehicles__heading">{{ section.settings.heading }}</h2>
    {% endif %}
    <div class="cr-vehicles__grid">
      {% for block in section.blocks %}
        {% if block.type == 'vehicle' %}
          {% assign fleet_url = section.settings.fleet_url | default: '/pages/fleet' %}
          <div class="cr-vehicles__card" {{ block.shopify_attributes }}>
            <a class="cr-vehicles__card-link" href="{{ fleet_url }}" aria-label="{{ block.settings.title }}">
              <div class="cr-vehicles__carousel" data-carousel>
                <div class="cr-vehicles__slides" data-slides>
                  {% assign slide_index = 0 %}
                  {% for img_i in (1..5) %}
                    {% assign img_key = 'image_' | append: img_i %}
                    {% assign img_val = block.settings[img_key] %}
                    {% if img_val != blank %}
                      <div class="cr-vehicles__slide{% if slide_index == 0 %} cr-vehicles__slide--active{% endif %}">
                        {{ img_val | image_url: width: 700 | image_tag: width: 700, loading: 'lazy', class: 'cr-vehicles__image', draggable: 'false' }}
                      </div>
                      {% assign slide_index = slide_index | plus: 1 %}
                    {% endif %}
                  {% endfor %}
                  {% if slide_index == 0 %}
                    <div class="cr-vehicles__slide cr-vehicles__slide--active">
                      <div class="cr-vehicles__image-placeholder"></div>
                    </div>
                  {% endif %}
                </div>
                <button class="cr-vehicles__arrow cr-vehicles__arrow--prev" aria-label="Previous" onclick="event.preventDefault()">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                </button>
                <button class="cr-vehicles__arrow cr-vehicles__arrow--next" aria-label="Next" onclick="event.preventDefault()">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                </button>
                <div class="cr-vehicles__dots" data-dots></div>
              </div>
            </a>
            <div class="cr-vehicles__content">
              <h3 class="cr-vehicles__title">{{ block.settings.title }}</h3>
              {% if block.settings.models != blank %}
                <p class="cr-vehicles__models">{{ block.settings.models }}</p>
              {% endif %}
              <div class="cr-vehicles__divider"></div>
              <ul class="cr-vehicles__features">
                {% if block.settings.feature_1 != blank %}
                  <li>
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#4a7cf5" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    {{ block.settings.feature_1 }}
                  </li>
                {% endif %}
                {% if block.settings.feature_2 != blank %}
                  <li>
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#4a7cf5" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    {{ block.settings.feature_2 }}
                  </li>
                {% endif %}
                {% if block.settings.feature_3 != blank %}
                  <li>
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#4a7cf5" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    {{ block.settings.feature_3 }}
                  </li>
                {% endif %}
              </ul>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

<script>
  document.querySelectorAll('[data-carousel]').forEach(function(carousel) {
    var slides = carousel.querySelectorAll('.cr-vehicles__slide');
    if (slides.length <= 1) {
      carousel.querySelector('.cr-vehicles__arrow--prev').style.display = 'none';
      carousel.querySelector('.cr-vehicles__arrow--next').style.display = 'none';
      return;
    }

    var current = 0;
    var dotsWrap = carousel.querySelector('[data-dots]');

    slides.forEach(function(_, i) {
      var dot = document.createElement('button');
      dot.className = 'cr-vehicles__dot' + (i === 0 ? ' cr-vehicles__dot--active' : '');
      dot.setAttribute('aria-label', 'Slide ' + (i + 1));
      dot.addEventListener('click', function(e) {
        e.preventDefault();
        goTo(i);
      });
      dotsWrap.appendChild(dot);
    });

    function goTo(n) {
      slides[current].classList.remove('cr-vehicles__slide--active');
      dotsWrap.children[current].classList.remove('cr-vehicles__dot--active');
      current = (n + slides.length) % slides.length;
      slides[current].classList.add('cr-vehicles__slide--active');
      dotsWrap.children[current].classList.add('cr-vehicles__dot--active');
    }

    // first slide already has --active from Liquid

    carousel.querySelector('.cr-vehicles__arrow--prev').addEventListener('click', function(e) {
      e.preventDefault();
      goTo(current - 1);
    });
    carousel.querySelector('.cr-vehicles__arrow--next').addEventListener('click', function(e) {
      e.preventDefault();
      goTo(current + 1);
    });
  });
</script>

{% stylesheet %}
.cr-vehicles__inner {
  max-width: 1200px;
  margin-inline: auto;
  padding-inline: clamp(16px, 5vw, 80px);
}

.cr-vehicles__heading {
  font-size: clamp(1.375rem, 2.5vw, 1.875rem);
  font-weight: 600;
  margin: 0 0 40px;
  color: #111;
}

.cr-vehicles__grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24px;
}

.cr-vehicles__card {
  border: 1px solid #e8e8e8;
  border-radius: 16px;
  overflow: hidden;
  background: #fff;
  display: flex;
  flex-direction: column;
  transition: box-shadow 0.2s;
}

.cr-vehicles__card:hover {
  box-shadow: 0 4px 24px rgba(0,0,0,0.09);
}

.cr-vehicles__card-link {
  display: block;
  text-decoration: none;
}

/* Carousel */
.cr-vehicles__carousel {
  position: relative;
  overflow: hidden;
  background: #f5f5f5;
}

.cr-vehicles__slides {
  position: relative;
  height: 240px;
}

.cr-vehicles__slide {
  position: absolute;
  inset: 0;
  opacity: 0;
  transition: opacity 0.35s ease;
  pointer-events: none;
}

.cr-vehicles__slide--active {
  opacity: 1;
  pointer-events: auto;
}


.cr-vehicles__image {
  width: 100%;
  height: 240px;
  object-fit: cover;
  display: block;
}

.cr-vehicles__image-placeholder {
  width: 100%;
  height: 240px;
  background: linear-gradient(135deg, #e8f0f8 0%, #d0e4f0 100%);
}

.cr-vehicles__arrow {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  width: 32px;
  height: 32px;
  border-radius: 50%;
  border: none;
  background: rgba(255,255,255,0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  color: #333;
  z-index: 2;
  transition: background 0.2s;
  box-shadow: 0 1px 4px rgba(0,0,0,0.15);
}

.cr-vehicles__arrow:hover {
  background: #fff;
}

.cr-vehicles__arrow--prev { left: 10px; }
.cr-vehicles__arrow--next { right: 10px; }

.cr-vehicles__dots {
  position: absolute;
  bottom: 10px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 5px;
  z-index: 2;
}

.cr-vehicles__dot {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  border: none;
  background: rgba(255,255,255,0.6);
  cursor: pointer;
  padding: 0;
  transition: background 0.2s;
}

.cr-vehicles__dot--active {
  background: #fff;
}

/* Content */
.cr-vehicles__content {
  padding: 20px 24px 24px;
  display: flex;
  flex-direction: column;
  flex: 1;
}

.cr-vehicles__title {
  font-size: 1.375rem;
  font-weight: 700;
  margin: 0 0 4px;
  color: #111;
  line-height: 1.2;
}

.cr-vehicles__models {
  font-size: 0.8125rem;
  color: #666;
  margin: 0;
  line-height: 1.5;
}

.cr-vehicles__divider {
  width: 40px;
  height: 2px;
  background: #4a7cf5;
  margin: 14px 0;
  border-radius: 2px;
}

.cr-vehicles__features {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.cr-vehicles__features li {
  display: flex;
  align-items: flex-start;
  gap: 8px;
  font-size: 0.8125rem;
  color: #333;
  line-height: 1.5;
}

.cr-vehicles__features li svg {
  flex-shrink: 0;
  margin-top: 2px;
}

@media (max-width: 768px) {
  .cr-vehicles__grid {
    grid-template-columns: 1fr;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Vehicle Cards",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Choose your vehicle class"
    },
    {
      "type": "url",
      "id": "fleet_url",
      "label": "Fleet page link"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "vehicle",
      "name": "Vehicle",
      "settings": [
        {
          "type": "image_picker",
          "id": "image_1",
          "label": "Photo 1"
        },
        {
          "type": "image_picker",
          "id": "image_2",
          "label": "Photo 2"
        },
        {
          "type": "image_picker",
          "id": "image_3",
          "label": "Photo 3"
        },
        {
          "type": "image_picker",
          "id": "image_4",
          "label": "Photo 4"
        },
        {
          "type": "image_picker",
          "id": "image_5",
          "label": "Photo 5"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Vehicle class",
          "default": "Business Class"
        },
        {
          "type": "text",
          "id": "models",
          "label": "Models",
          "default": "Mercedes E-Class, BMW 5 Series, Audi A6, or similar"
        },
        {
          "type": "text",
          "id": "feature_1",
          "label": "Feature 1",
          "default": "Fits up to 3 people"
        },
        {
          "type": "text",
          "id": "feature_2",
          "label": "Feature 2",
          "default": "Fits 2 carry-on bags, or 2 standard check-in bags"
        },
        {
          "type": "text",
          "id": "feature_3",
          "label": "Feature 3",
          "default": "Available in most of our business districts"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Vehicle Cards"
    }
  ]
}
{% endschema %}
