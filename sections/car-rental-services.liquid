<div class="cr-services" style="background: {{ section.settings.background_color }}; padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;">
  {% if section.settings.heading != blank %}
    <div class="cr-services__heading-wrap">
      <h2 class="cr-services__heading">{{ section.settings.heading }}</h2>
    </div>
  {% endif %}
  <div class="cr-services__grid" id="cr-services-grid">
    {% for block in section.blocks %}
      {% if block.type == 'service' %}
        <div class="cr-services__card" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            <a class="cr-services__image-link" {% if block.settings.link != blank %}href="{{ block.settings.link }}"{% endif %}>
              {{ block.settings.image | image_url: width: 800 | image_tag: width: 800, loading: 'lazy', class: 'cr-services__image' }}
            </a>
          {% else %}
            <div class="cr-services__image-placeholder"></div>
          {% endif %}
          <div class="cr-services__content">
            {% if block.settings.category != blank %}
              <span class="cr-services__category">{{ block.settings.category }}</span>
            {% endif %}
            <h3 class="cr-services__title">{{ block.settings.title }}</h3>
            {% if block.settings.description != blank %}
              <p class="cr-services__description">{{ block.settings.description }}</p>
            {% endif %}
            {% if block.settings.link != blank %}
              <a class="cr-services__link" href="{{ block.settings.link }}">
                {{ block.settings.label | default: block.settings.link_label | default: 'Learn more' }}
              </a>
            {% endif %}
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</div>

{% stylesheet %}
.cr-services__heading-wrap {
  max-width: 1200px;
  margin-inline: auto;
  padding-inline: clamp(16px, 5vw, 80px);
  margin-bottom: 40px;
}

.cr-services__heading {
  font-size: 1.75rem;
  font-weight: 600;
  margin: 0;
  color: #111;
}

.cr-services__grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24px;
  max-width: 1200px;
  margin-inline: auto;
  padding-inline: clamp(16px, 5vw, 80px);
}

.cr-services__card {
  display: flex;
  flex-direction: column;
  gap: 0;
  border-radius: 8px;
  overflow: hidden;
  border: 1px solid #e8e8e8;
}

.cr-services__image-link {
  display: block;
  overflow: hidden;
}

.cr-services__image {
  width: 100%;
  height: 260px;
  object-fit: cover;
  display: block;
  transition: transform 0.4s ease;
}

.cr-services__image-link:hover .cr-services__image {
  transform: scale(1.03);
}

.cr-services__image-placeholder {
  width: 100%;
  height: 260px;
  background: #f0f0f0;
}

.cr-services__content {
  padding: 24px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.cr-services__category {
  font-size: 0.75rem;
  color: #888;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.cr-services__title {
  font-size: 1.125rem;
  font-weight: 600;
  margin: 0;
  color: #111;
  line-height: 1.3;
}

.cr-services__description {
  font-size: 0.875rem;
  color: #555;
  line-height: 1.6;
  margin: 0;
}

.cr-services__link {
  display: inline-block;
  align-self: flex-start;
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #fff;
  text-decoration: none;
  background: #0f63bd;
  border: 1px solid #0f63bd;
  padding: 10px 20px;
  border-radius: 4px;
  margin-top: 8px;
  transition: background 0.2s;
  width: fit-content;
}

.cr-services__link:hover {
  background: #0a4f99;
  border-color: #0a4f99;
}

.cr-services__labels {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24px;
  max-width: 1200px;
  margin-inline: auto;
  padding-inline: clamp(16px, 5vw, 80px);
  margin-top: 16px;
}

.cr-services__label-btn {
  display: block;
  text-align: center;
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #111;
  text-decoration: none;
  padding: 14px;
  border: 1px solid #ddd;
  border-radius: 4px;
  transition: background 0.2s, color 0.2s;
}

.cr-services__label-btn:hover {
  background: #111;
  color: #fff;
}

@media (max-width: 768px) {
  .cr-services__grid {
    grid-template-columns: 1fr;
  }

  .cr-services__image,
  .cr-services__image-placeholder {
    height: 220px;
  }

  .cr-services__labels {
    grid-template-columns: 1fr;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Car Rental Services",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our services"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "service",
      "name": "Service card",
      "limit": 4,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "category",
          "label": "Category label",
          "default": "Airport transfers"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Smooth landings, every time."
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Delayed flight? Chauffeurs track arrivals and adjust accordingly. Plus, you have 1 hour of complimentary wait time just in case."
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link label",
          "default": "Learn more"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link URL"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Bottom label (caps)",
          "default": "ONE WAY TRANSFERS"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Car Rental Services",
      "blocks": [
        {
          "type": "service",
          "settings": {
            "category": "Airport transfers",
            "title": "Smooth landings, every time.",
            "description": "Delayed flight? Chauffeurs track arrivals and adjust accordingly. Plus, you have 1 hour of complimentary wait time just in case.",
            "link_label": "Learn more"
          }
        },
        {
          "type": "service",
          "settings": {
            "category": "Hourly and full day hire",
            "title": "Seize the day.",
            "description": "Reserve a dedicated chauffeur from 2 to 24 hours. They'll be on standby as long as you need them.",
            "link_label": "Learn more"
          }
        }
      ]
    }
  ]
}
{% endschema %}
